msgid "pricing_pro_mv_desc"
msgstr "For Multi-Vendor and similar setups—the same Pro capabilities at a higher footprint."

msgid "pricing_plan_activations_note"
msgstr "Each subscription includes two activations. Use one for your production storefront and one for development or staging."

