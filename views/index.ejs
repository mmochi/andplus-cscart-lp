<!DOCTYPE html>
<html lang="<%= lang %>" class="<%= showEarlyAccessBanner ? 'has-ea-dock' : '' %>">
  <head>
    <!-- Document -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= __('page_title') %></title>
    <link rel="icon" type="image/png" href="<%= basePath %>/img/safecache300.png" sizes="any" />
    <link rel="apple-touch-icon" href="<%= basePath %>/img/safecache300.png" />

    <!-- Primary SEO -->
    <meta name="description" content="<%= __('meta_description') %>" />
    <meta name="keywords" content="<%= __('meta_keywords') %>" />
    <meta name="author" content="<%= __('meta_author') %>" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href="<%= canonicalUrl %>" />
    <link
      rel="sitemap"
      type="application/xml"
      href="<%= typeof sitemapFileUrl !== 'undefined' && sitemapFileUrl ? sitemapFileUrl : (typeof basePath !== 'undefined' && basePath ? basePath + '/sitemap.xml' : '/sitemap.xml') %>"
    />
    <link rel="alternate" hreflang="en" href="<%= alternateUrlEn %>" />
    <link rel="alternate" hreflang="ja" href="<%= alternateUrlJa %>" />
    <link rel="alternate" hreflang="x-default" href="<%= alternateUrlEn %>" />

    <!-- Open Graph -->
    <% if (fbAppId) { %>
      <meta property="fb:app_id" content="<%= fbAppId %>" />
    <% } %>
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="<%= __('og_site_name') %>" />
    <meta property="og:title" content="<%= __('page_title') %>" />
    <meta property="og:description" content="<%= __('meta_description') %>" />
    <meta property="og:url" content="<%= canonicalUrl %>" />
    <meta property="og:locale" content="<%= lang === 'ja' ? 'ja_JP' : 'en_US' %>" />
    <meta property="og:locale:alternate" content="<%= lang === 'ja' ? 'en_US' : 'ja_JP' %>" />
    <% if (ogImageUrl) { %>
      <meta property="og:image" content="<%= ogImageUrl %>" />
      <% if (ogImageUrl.indexOf('https://') === 0) { %>
        <meta property="og:image:secure_url" content="<%= ogImageUrl %>" />
      <% } %>
      <meta property="og:image:width" content="<%= ogImageWidth %>" />
      <meta property="og:image:height" content="<%= ogImageHeight %>" />
      <meta property="og:image:alt" content="<%= __('page_title') %>" />
    <% } %>

    <!-- Twitter（summary_large_image＝大画像カード。PC・モバイル同一の meta） -->
    <meta name="twitter:card" content="<%= ogImageUrl ? 'summary_large_image' : 'summary' %>" />
    <meta name="twitter:title" content="<%= __('page_title') %>" />
    <meta name="twitter:description" content="<%= __('meta_description') %>" />
    <% if (ogImageUrl) { %>
      <meta name="twitter:image" content="<%= ogImageUrl %>" />
    <% } %>

    <!-- JSON-LD -->
    <script type="application/ld+json">
<%- prettyJson(jsonLd) %>
    </script>

    <% if (gaMeasurementId) { %>
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaMeasurementId %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      /* page_location を canonical と揃える（サブパス配信・?lang= の取り違い対策）。コンソールの "to undefined" は gtag 内部デバッグ表示で多くは問題にならない */
      gtag('config', '<%= gaMeasurementId %>', <%- JSON.stringify({ page_location: canonicalUrl }) %>);
    </script>
    <% } %>

    <link rel="stylesheet" href="<%= basePath %>/style.css" />
  </head>
  <body class="<%= showEarlyAccessBanner ? 'has-ea-dock' : '' %>">
    <a class="skip-link" href="#main"><%= __('skip_to_content') %></a>

    <div class="site-top site-top--sticky">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="logo" href="#hero">
            <img
              class="logo__mark"
              src="<%= basePath %>/img/safecache300.png"
              width="300"
              height="300"
              alt=""
              decoding="async"
            />
            <span class="logo__text"><%= __('brand_name') %></span>
          </a>
          <nav class="nav" aria-label="<%= __('nav_primary_aria') %>">
            <a class="nav__link" href="#problem"><%= __('nav_problem') %></a>
            <a class="nav__link" href="#story"><%= __('nav_story') %></a>
            <a class="nav__link" href="#story"><%= __('nav_screens_primary') %></a>
            <a class="nav__link" href="#pro-value"><%= __('nav_pro_value') %></a>
            <a class="nav__link" href="#core"><%= __('nav_features') %></a>
            <a class="nav__link" href="#pricing"><%= __('nav_pricing') %></a>
          </nav>
          <div class="lang" role="group" aria-label="<%= __('nav_lang_group_aria') %>">
            <a
              class="lang__btn <%= lang === 'en' ? 'is-active' : '' %>"
              href="<%= langUrl('en') %>"
              aria-label="<%= __('nav_lang_en') %>"
              lang="en"
            >
              <span class="lang__label lang__label--full"><%= __('nav_lang_en') %></span>
              <span class="lang__label lang__label--abbr" aria-hidden="true"><%= __('nav_lang_en_abbr') %></span>
            </a>
            <a
              class="lang__btn <%= lang === 'ja' ? 'is-active' : '' %>"
              href="<%= langUrl('ja') %>"
              aria-label="<%= __('nav_lang_ja') %>"
              lang="ja"
            >
              <span class="lang__label lang__label--full"><%= __('nav_lang_ja') %></span>
              <span class="lang__label lang__label--abbr" aria-hidden="true"><%= __('nav_lang_ja_abbr') %></span>
            </a>
          </div>
        </div>
      </header>
    </div>

    <% if (showEarlyAccessBanner) { %>
      <aside
        id="ea-floating-banner"
        class="early-access-banner early-access-banner--floating"
        role="region"
        aria-label="<%= __('early_access_aria') %>"
        aria-hidden="true"
      >
        <div class="early-access-banner__inner">
          <div class="early-access-banner__copy">
            <p class="early-access-banner__line early-access-banner__line--title"><%= __('early_access_line1') %></p>
            <p class="early-access-banner__line"><%= __('early_access_line2') %></p>
            <p class="early-access-banner__line"><%= __('early_access_line3') %></p>
          </div>
          <button type="button" id="early-access-coupon-btn" class="early-access-banner__cta"><%= __('early_access_cta') %></button>
        </div>
      </aside>
      <script type="application/json" id="ea-coupon-config">
<%- prettyJson(
          {
            code: eaCouponCode,
            alert: __('early_access_alert').replace(/%s/g, eaCouponCode),
            hint: __('ea_checkout_hint')
          },
          8
        ) %>
      </script>
    <% } %>

    <div
      id="ea-modal"
      class="ea-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="ea-modal-title"
      aria-hidden="true"
      hidden
    >
      <div class="ea-modal__backdrop" aria-hidden="true"></div>
      <div class="ea-modal__panel">
        <h2 id="ea-modal-title" class="ea-modal__title"><%= __('ea_modal_title') %></h2>
        <p id="ea-modal-body" class="ea-modal__body"></p>
        <button type="button" id="ea-modal-ok" class="ea-modal__ok btn btn--primary"><%= __('ea_modal_ok') %></button>
      </div>
    </div>

    <main id="main">
      <section id="hero" class="section section--hero" aria-labelledby="hero-heading">
        <div class="container hero-layout">
          <div class="hero-layout__copy">
            <p class="kicker"><%= __('hero_kicker') %></p>
            <p class="hero-audience"><%= __('hero_audience') %></p>
            <h1 id="hero-heading" class="hero-title">
              <span class="hero-title__line"><%= __('hero_title_line1') %></span>
              <span class="hero-title__line"><%= __('hero_title_line2') %></span>
            </h1>
            <p class="lead"><%= __('hero_subtitle') %></p>
            <div class="hero-cta">
              <a class="btn btn--primary" href="#pricing"><%= __('hero_cta_primary') %></a>
              <a class="btn btn--ghost" href="#story"><%= __('hero_cta_secondary') %></a>
            </div>
          </div>
          <div class="hero-layout__visual">
            <div class="hero-visual hero-visual--photo">
              <img
                class="hero-visual__img"
                src="<%= basePath %>/img/<%= lang === 'ja' ? 'backups.png' : 'backups-en.png' %>"
                width="<%= lang === 'ja' ? 2082 : 2080 %>"
                height="<%= lang === 'ja' ? 1542 : 1544 %>"
                alt="<%= __('hero_visual_alt') %>"
                loading="eager"
                decoding="async"
              />
            </div>
          </div>
        </div>
      </section>

      <section id="already" class="section section--urgency" aria-labelledby="urgency-heading">
        <div class="container">
          <p class="section-label"><%= __('urgency_section_label') %></p>
          <h2 id="urgency-heading" class="section-title"><%= __('urgency_title') %></h2>
          <p class="problem-checklist-intro"><%= __('urgency_checklist_intro') %></p>
          <ul class="problem-checklist problem-checklist--signal">
            <li><%= __('urgency_checklist_1') %></li>
            <li><%= __('urgency_checklist_2') %></li>
            <li><%= __('urgency_checklist_3') %></li>
          </ul>
          <p class="prose prose--tight urgency-bridge"><%= __('urgency_bridge') %></p>
        </div>
      </section>

      <section id="story" class="section section--alt" aria-labelledby="story-heading">
        <div class="container">
          <p class="section-label"><%= __('story_section_label') %></p>
          <h2 id="story-heading" class="section-title"><%= __('story_title') %></h2>
          <p class="lead lead--tight"><%= __('story_lead') %></p>
          <div class="story-flow story-flow--stacked" role="region" aria-label="<%= __('story_flow_aria') %>">
            <div class="story-flow__slot">
              <div class="story-flow__card">
                <span class="story-flow__card-inner">
                  <span class="story-flow__viz story-flow__viz--rules" aria-hidden="true">
                    <span class="story-mock story-mock--rules">
                      <span class="story-mock__chrome"></span>
                      <span class="story-mock__rules-body">
                        <span class="story-mock__rule-row"><span class="story-mock__knob"></span><span class="story-mock__rail"><span class="story-mock__thumb"></span></span></span>
                        <span class="story-mock__rule-row"><span class="story-mock__knob"></span><span class="story-mock__rail story-mock__rail--alt"><span class="story-mock__thumb"></span></span></span>
                        <span class="story-mock__rule-row story-mock__rule-row--short"><span class="story-mock__chip"></span></span>
                      </span>
                    </span>
                  </span>
                  <span class="story-flow__text"><%= __('story_step_1') %></span>
                </span>
              </div>
            </div>
            <div class="story-flow__sep story-flow__sep--between" aria-hidden="true"><span class="story-flow__arrow">↓</span></div>
            <div class="story-flow__slot">
              <div class="story-flow__card">
                <span class="story-flow__card-inner">
                  <span class="story-flow__viz story-flow__viz--broken" aria-hidden="true">
                    <span class="story-mock story-mock--broken">
                      <span class="story-mock__broken-frame">
                        <span class="story-mock__broken-grid">
                          <span class="story-mock__broken-cell"></span>
                          <span class="story-mock__broken-cell"></span>
                          <span class="story-mock__broken-cell story-mock__broken-cell--blank"></span>
                          <span class="story-mock__broken-cell story-mock__broken-cell--blank"></span>
                        </span>
                        <span class="story-mock__broken-strip"></span>
                      </span>
                      <span class="story-mock__broken-glitch"></span>
                    </span>
                  </span>
                  <span class="story-flow__text"><%= __('story_step_2') %></span>
                </span>
              </div>
            </div>
            <div class="story-flow__sep story-flow__sep--between" aria-hidden="true"><span class="story-flow__arrow">↓</span></div>
            <div class="story-flow__slot">
              <div class="story-flow__card story-flow__card--rollback">
                <span class="story-flow__card-inner">
                  <span class="story-flow__viz story-flow__viz--history" aria-hidden="true">
                    <div class="story-mock story-mock--history-ui">
                      <div class="story-hui__head"><%= __('story_history_panel_title') %></div>
                      <ol class="story-hui__list">
                        <li class="story-hui__row story-hui__row--target">
                          <span class="story-hui__time"><%= __('story_history_time_1') %></span>
                          <div class="story-hui__main">
                            <span class="story-hui__badge story-hui__badge--ok"><%= __('story_history_label_ok') %></span>
                            <span class="story-hui__desc"><%= __('story_history_desc_ok') %></span>
                          </div>
                          <span class="story-hui__target"><%= __('story_history_target_badge') %></span>
                        </li>
                        <li class="story-hui__row">
                          <span class="story-hui__time"><%= __('story_history_time_2') %></span>
                          <div class="story-hui__main">
                            <span class="story-hui__badge story-hui__badge--chg"><%= __('story_history_label_change') %></span>
                            <span class="story-hui__desc"><%= __('story_history_desc_change') %></span>
                          </div>
                        </li>
                        <li class="story-hui__row story-hui__row--bad">
                          <span class="story-hui__time"><%= __('story_history_time_3') %></span>
                          <div class="story-hui__main">
                            <span class="story-hui__badge story-hui__badge--bad"><%= __('story_history_label_bad') %></span>
                            <span class="story-hui__desc"><%= __('story_history_desc_bad') %></span>
                          </div>
                        </li>
                      </ol>
                      <div class="story-hui__rollback"><%= __('story_history_rollback_line') %></div>
                      <div class="story-hui__done">
                        <span class="story-hui__done-icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
                        </span>
                        <span class="story-hui__done-text"><%= __('story_history_result_line') %></span>
                      </div>
                    </div>
                  </span>
                  <span class="story-flow__text"><%= __('story_step_3') %></span>
                </span>
              </div>
            </div>
            <div class="story-flow__sep story-flow__sep--between" aria-hidden="true"><span class="story-flow__arrow">↓</span></div>
            <div class="story-flow__slot">
              <div class="story-flow__card">
                <span class="story-flow__card-inner">
                  <span class="story-flow__viz story-flow__viz--inspect" aria-hidden="true">
                    <span class="story-mock story-mock--inspect">
                      <span class="story-mock__inspect-split">
                        <span class="story-mock__inspect-pane story-mock__inspect-pane--before">
                          <span class="story-mock__inspect-dot"></span>
                          <span class="story-mock__inspect-line"></span>
                          <span class="story-mock__inspect-line story-mock__inspect-line--short"></span>
                        </span>
                        <span class="story-mock__inspect-pane story-mock__inspect-pane--after">
                          <span class="story-mock__inspect-check" aria-hidden="true">
                            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
                          </span>
                          <span class="story-mock__inspect-line"></span>
                        </span>
                      </span>
                      <span class="story-mock__inspect-loupe" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
                      </span>
                    </span>
                  </span>
                  <span class="story-flow__text"><%= __('story_step_4') %></span>
                </span>
              </div>
            </div>
          </div>

          <div id="screens" class="story-gallery-wrap story-gallery-wrap--hidden" aria-labelledby="screens-heading" aria-hidden="true">
            <p class="section-label"><%= __('screens_section_title') %></p>
            <h3 id="screens-heading" class="section-title section-title--fuse"><%= __('screens_title') %></h3>
            <p class="lead lead--tight"><%= __('screens_intro') %></p>
            <p class="prose prose--note"><%= __('screens_note') %></p>
            <div class="screens-gallery screens-gallery--fused" role="region" aria-label="<%= __('screens_gallery_aria') %>">
            <div class="screens-expand" id="screens-shot-backups">
              <label class="screens-expand__card">
                <input type="checkbox" class="screens-expand__state" />
                <div class="screens-expand__frame">
                  <img
                    class="screens-expand__img"
                    src="<%= basePath %>/img/<%= lang === 'ja' ? 'backups.png' : 'backups-en.png' %>"
                    width="<%= lang === 'ja' ? 2082 : 2080 %>"
                    height="<%= lang === 'ja' ? 1542 : 1544 %>"
                    alt="<%= __('screens_backups_alt') %>"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <span class="screens-expand__caption"><%= __('screens_backups_caption') %></span>
                <span class="screens-expand__toggle-line">
                  <span class="screens-expand__hint screens-expand__hint--more"><%= __('screens_expand_more') %></span>
                  <span class="screens-expand__hint screens-expand__hint--less"><%= __('screens_expand_less') %></span>
                </span>
              </label>
            </div>
            <div class="screens-expand" id="screens-shot-cache-rules">
              <label class="screens-expand__card">
                <input type="checkbox" class="screens-expand__state" />
                <div class="screens-expand__frame">
                  <img
                    class="screens-expand__img"
                    src="<%= basePath %>/img/<%= lang === 'ja' ? 'cache-rules.png' : 'cache-rules-en.png' %>"
                    width="<%= lang === 'ja' ? 2364 : 2274 %>"
                    height="<%= lang === 'ja' ? 2140 : 2148 %>"
                    alt="<%= __('screens_cache_rules_alt') %>"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <span class="screens-expand__caption"><%= __('screens_cache_rules_caption') %></span>
                <span class="screens-expand__toggle-line">
                  <span class="screens-expand__hint screens-expand__hint--more"><%= __('screens_expand_more') %></span>
                  <span class="screens-expand__hint screens-expand__hint--less"><%= __('screens_expand_less') %></span>
                </span>
              </label>
            </div>
            <div class="screens-expand" id="screens-shot-monitor">
              <label class="screens-expand__card">
                <input type="checkbox" class="screens-expand__state" />
                <div class="screens-expand__frame">
                  <img
                    class="screens-expand__img"
                    src="<%= basePath %>/img/<%= lang === 'ja' ? 'monitor.png' : 'monitor-en.png' %>"
                    width="<%= lang === 'ja' ? 2078 : 2080 %>"
                    height="<%= lang === 'ja' ? 1040 : 1026 %>"
                    alt="<%= __('screens_monitor_alt') %>"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <span class="screens-expand__caption"><%= __('screens_monitor_caption') %></span>
                <span class="screens-expand__toggle-line">
                  <span class="screens-expand__hint screens-expand__hint--more"><%= __('screens_expand_more') %></span>
                  <span class="screens-expand__hint screens-expand__hint--less"><%= __('screens_expand_less') %></span>
                </span>
              </label>
            </div>
            <div class="screens-expand" id="screens-shot-ajax">
              <label class="screens-expand__card">
                <input type="checkbox" class="screens-expand__state" />
                <div class="screens-expand__frame">
                  <img
                    class="screens-expand__img"
                    src="<%= basePath %>/img/<%= lang === 'ja' ? 'ajax.png' : 'ajax-en.png' %>"
                    width="<%= lang === 'ja' ? 2360 : 2360 %>"
                    height="<%= lang === 'ja' ? 2144 : 2098 %>"
                    alt="<%= __('screens_ajax_alt') %>"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <span class="screens-expand__caption"><%= __('screens_ajax_caption') %></span>
                <span class="screens-expand__toggle-line">
                  <span class="screens-expand__hint screens-expand__hint--more"><%= __('screens_expand_more') %></span>
                  <span class="screens-expand__hint screens-expand__hint--less"><%= __('screens_expand_less') %></span>
                </span>
              </label>
            </div>
          </div>
          </div>
        </div>
      </section>

      <section id="problem" class="section" aria-labelledby="problem-heading">
        <div class="container">
          <p class="section-label"><%= __('problem_section_title') %></p>
          <h2 id="problem-heading" class="section-title"><%= __('problem_title') %></h2>
          <p class="problem-checklist-intro"><%= __('problem_checklist_intro') %></p>
          <ul class="problem-checklist">
            <li><%= __('problem_checklist_1') %></li>
            <li><%= __('problem_checklist_2') %></li>
            <li><%= __('problem_checklist_3') %></li>
          </ul>
          <p class="prose"><%= __('problem_p1') %></p>
          <p class="prose"><%= __('problem_p2') %></p>
          <p class="prose"><%= __('problem_p3') %></p>
        </div>
      </section>

      <section id="solution" class="section section--alt" aria-labelledby="solution-heading">
        <div class="container">
          <p class="section-label"><%= __('solution_section_title') %></p>
          <h2 id="solution-heading" class="section-title"><%= __('solution_title') %></h2>
          <p class="prose"><%= __('solution_p1') %></p>
          <p class="prose"><%= __('solution_p2') %></p>
          <p class="pro-disclaimer"><%= __('pro_disclaimer') %></p>
        </div>
      </section>

      <section id="pro-value" class="section" aria-labelledby="pro-value-heading">
        <div class="container">
          <p class="section-label"><%= __('pro_value_section_label') %></p>
          <h2 id="pro-value-heading" class="section-title"><%= __('pro_value_title') %></h2>
          <p class="lead lead--tight"><%= __('pro_value_lead') %></p>
          <p class="prose prose--note plan-cf-note"><%= __('plan_cf_note') %></p>
        </div>
      </section>

      <section id="core" class="section" aria-labelledby="core-heading">
        <div class="container">
          <p class="section-label"><%= __('core_section_title') %></p>
          <h2 id="core-heading" class="section-title"><%= __('core_title') %></h2>
          <p class="lead lead--tight"><%= __('core_intro') %></p>
          <ul class="feature-grid">
            <li class="feature-card">
              <span class="feature-card__icon" aria-hidden="true"
                ><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="7" rx="1.5" /><rect x="4" y="13" width="16" height="7" rx="1.5" /></svg
              ></span>
              <div class="feature-card__main">
                <h3 class="feature-card__title"><%= __('core_feature_backup_title') %></h3>
                <p class="feature-card__text"><%= __('core_feature_backup_desc') %></p>
              </div>
            </li>
            <li class="feature-card">
